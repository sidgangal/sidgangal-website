---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { findRelatedPosts } from '../../utils/related-posts';

export async function getStaticPaths() {
  const posts = await getCollection('build');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = [
  ...await getCollection('build'),
  ...await getCollection('invest'),
  ...await getCollection('thrive'),
];
const relatedPosts = findRelatedPosts(
  post.data.slug,
  'build',
  post.data.topics ?? [],
  allPosts,
);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pillar="build"
  publishedAt={post.data.publishedAt.toISOString()}
  topics={post.data.topics}
  content={post.body}
  slug={post.data.slug}
  keywords={post.data.keywords}
  updatedAt={post.data.updatedAt?.toISOString()}
  coverImage={post.data.coverImage}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
