---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { findRelatedPosts } from '../../utils/related-posts';
import { getEntrySlug } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('thrive');
  return posts.map((post) => ({
    params: { slug: getEntrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = getEntrySlug(post);
const { Content } = await render(post);

const allPosts = [
  ...await getCollection('build'),
  ...await getCollection('invest'),
  ...await getCollection('thrive'),
];
const relatedPosts = findRelatedPosts(
  slug,
  'thrive',
  post.data.topics ?? [],
  allPosts,
);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pillar="thrive"
  publishedAt={post.data.publishedAt.toISOString()}
  topics={post.data.topics}
  content={post.body}
  slug={slug}
  keywords={post.data.keywords}
  updatedAt={post.data.updatedAt?.toISOString()}
  coverImage={post.data.coverImage}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
